      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Hunter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Sung Jin-Woo\",\n    \"email\": \"hunter@test.com\",\n    \"password\": \"Shadow@1234\",\n    \"phone\": 1234567890,\n    \"profile_pic\": \"\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/register",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "register"]
            }
          }
        },
        {
          "name": "Login Hunter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseData = pm.response.json();",
                  "if(responseData.token) {",
                  "    pm.collectionVariables.set(\"token\", responseData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"hunter@test.com\",\n    \"password\": \"Shadow@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/login",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "login"]
            },
            "description": "Logs in and automatically saves the JWT token to the collection variables for future requests."
          }
        }
      ]
    },
